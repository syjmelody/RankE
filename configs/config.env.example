#!/bin/bash
# Copy this file to configs/config.env and fill in your local paths.

# Repo root
export CODE_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Storage / outputs
export STORAGE_ROOT="/path/to/storage"
export PROJECT_OUTPUT_ROOT="${STORAGE_ROOT}/outputs"
export PRETRAINED_ROOT="${STORAGE_ROOT}/pretrained"

# Base model checkpoints
export VQ_CKPT_PATH="${PRETRAINED_ROOT}/llamagen/vq_ds16_t2i.pt"
export GPT_CKPT_PATH_STAGE1="${PRETRAINED_ROOT}/llamagen/t2i_XL_stage1_256.pt"
export GPT_CKPT_PATH_STAGE2="${PRETRAINED_ROOT}/llamagen/t2i_XL_stage2_512.pt"
export GPT_INIT_CKPT="${GPT_CKPT_PATH_STAGE2}"
export GPT_INIT_CKPT_STAGE2="${GPT_CKPT_PATH_STAGE2}"
export T5_PATH="${PRETRAINED_ROOT}/google"
export JANUS_MODEL_PATH="${PRETRAINED_ROOT}/deepseek-ai/Janus-Pro-1B"

# Reward / discriminator checkpoints
export CLIP_PATH="${PRETRAINED_ROOT}/openai/clip-vit-large-patch14"
export HPS_ROOT="${PRETRAINED_ROOT}/HPSv2"
export DINO_PATH="${PRETRAINED_ROOT}/facebook/dinov3-vits16-pretrain-lvd1689m"
export AES_REW_PATH="${PRETRAINED_ROOT}/aesthetic/sac+logos+ava1-l14-linearMSE.pth"
export HPSV2_MODEL_PATH="${PRETRAINED_ROOT}/HPSv2/HPS_v2.1_compressed.pt"
export GENEVAL_MASK2FORMER_PATH="${PRETRAINED_ROOT}/geneval_mask2former"

# Optional dataset-registry roots used by dataset/sft_dataset.py
export RANKE_JSON_ROOT="${STORAGE_ROOT}/datasets/t2i_2m"
export RANKE_WDS_ROOT="${STORAGE_ROOT}/datasets"

# Datasets
export SCALING_BLIP3O_ROOT="${STORAGE_ROOT}/datasets/BLIP3o/Scaling_Experiments"
export HPDV2_TRAIN_ROOT="${STORAGE_ROOT}/datasets/HPDv2"
export HPDV2_EVAL_ROOT="${STORAGE_ROOT}/datasets/HPDv2"
export COCO_REF_DIR="${STORAGE_ROOT}/datasets/coco2014"
export EVAL_PROMPT_FILE="${CODE_ROOT}/evaluations/t2i/coco_captions.csv"
export EVAL_PROMPT_FILE_COCO="${CODE_ROOT}/evaluations/t2i/coco_captions.csv"
export GENEVAL_PROMPTS_FILE="${CODE_ROOT}/evaluations/geneval/prompts/evaluation_metadata.jsonl"

# Python / cache
export PYTHONPATH="${CODE_ROOT}:${CODE_ROOT}/evaluations/HPSv2:${PYTHONPATH}"
export XDG_CACHE_HOME="${STORAGE_ROOT}/.cache"
